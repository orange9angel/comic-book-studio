{
  "name": "comic-book-studio",
  "version": "0.1.0",
  "description": "Independent prototype pipeline for voiced comic-book page-turn videos.",
  "type": "module",
  "scripts": {
    "render": "node render_frames.mjs",
    "render:sample": "node render_frames.mjs --sample=8,14,21",
    "audio": "python build_audio_edge.py",
    "mux": "ffmpeg -y -framerate 24 -i ./frames/frame_%05d.png -i ./assets/audio/mixed.wav -c:v libx264 -pix_fmt yuv420p -c:a aac -b:a 192k -shortest ./output/starlight_courier_baked_kaiti.mp4"
  },
  "keywords": [
    "comic-book",
    "threejs",
    "tts",
    "ffmpeg",
    "video-rendering"
  ],
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^24.41.0",
    "three": "^0.183.2"
  }
}
