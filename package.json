{
  "name": "comic-book-studio",
  "version": "0.1.0",
  "description": "Independent prototype pipeline for voiced comic-book page-turn videos.",
  "type": "module",
  "scripts": {
    "render": "node render_frames.mjs",
    "render:sample": "node render_frames.mjs --sample=8,14,21",
    "audio": "python build_audio_edge.py",
    "mux": "node mux.js",
    "build": "npm run audio && npm run render && npm run mux",
    "inspect": "node inspect.js"
  },
  "keywords": [
    "comic-book",
    "threejs",
    "tts",
    "ffmpeg",
    "video-rendering"
  ],
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^24.41.0",
    "three": "^0.183.2"
  }
}
